# ---------------------------------------------------------------------------
# Copy this file to ".env" before running the project:
#   cp .env.example .env
# ---------------------------------------------------------------------------

# PostgreSQL connection string.
# These credentials MUST match docker-compose.yml.
DATABASE_URL="postgresql://zpo:zpo@localhost:5432/zpo?schema=public"

# Secret used to sign session JWTs (HS256).
# Generate a strong one for anything real, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="dev-only-secret-change-me-please-use-a-long-random-string"

# Name of the httpOnly session cookie.
AUTH_COOKIE_NAME="zpo_session"

# Session lifetime in seconds (default: 7 days).
AUTH_SESSION_MAX_AGE="604800"
